# Google Places API key used at build time by scripts/fetch-reviews.mjs
# Server-side only — never bundled into the browser build.
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" for the project.
GOOGLE_PLACES_API_KEY=

# Optional: override the default Place ID (Kickstart Kids Soccer, Palm Beach FL)
# PLACE_ID=ChIJu4cDUyYr80gRmvtFi7vk7Iw
